        <guid>https://xiaoweihome.github.io/p/%E9%99%B6%E5%96%86%E6%99%AE%E9%80%9A%E6%9C%8B%E5%8F%8B%E5%92%8C%E5%A3%B0%E5%88%86%E6%9E%90/</guid>
        <description>&lt;img src="https://xiaoweihome.github.io/p/%E9%99%B6%E5%96%86%E6%99%AE%E9%80%9A%E6%9C%8B%E5%8F%8B%E5%92%8C%E5%A3%B0%E5%88%86%E6%9E%90/1.jpg" alt="Featured image of post 陶喆《普通朋友》和声分析" /&gt;&lt;details&gt;
