        <item>
        <title>工具</title>
        <link>http://localhost:1313/%E5%B7%A5%E5%85%B7/</link>
        <pubDate>Tue, 28 May 2019 00:00:00 +0000</pubDate>
        
        <guid>http://localhost:1313/%E5%B7%A5%E5%85%B7/</guid>
        <description>&lt;h2 id=&#34;超简约节拍器&#34;&gt;超简约节拍器
&lt;/h2&gt;&lt;html lang=&#34;en&#34;&gt;
&lt;head&gt;
    &lt;meta charset=&#34;UTF-8&#34;&gt;
    &lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;&gt;
    &lt;title&gt;Web 节拍器&lt;/title&gt;
    &lt;style&gt;
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #f5f5f5;
            padding-bottom: 150px; /* 增加底部的空白区域，避免被评论顶上 */
        }
        .metronome {
            text-align: center;
            background: #fff;
            padding: 40px;
            border-radius: 14px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-top: 50px; /* 向下偏移，避免和页面顶部过于贴近 */
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }
        .metronome input {
            width: 80px;
            margin: 10px 0;
        }
        .metronome button {
            background: #007bff;
            color: #fff ;
            border: none;
            padding: 20px 50px; /* 调整按钮大小 */
            font-size: 20px;
            cursor: pointer;
            border-radius: 12px;
            margin-top: 10px;
        }
        .metronome button:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;div class=&#34;metronome&#34;&gt;
        &lt;label for=&#34;bpm&#34;&gt;BPM: &lt;/label&gt;
        &lt;input type=&#34;number&#34; id=&#34;bpm&#34; value=&#34;60&#34; min=&#34;40&#34; max=&#34;240&#34; step=&#34;1&#34;&gt;
        &lt;br&gt;
        &lt;label for=&#34;noteType&#34;&gt;节拍音符: &lt;/label&gt;
        &lt;select id=&#34;noteType&#34;&gt;
            &lt;option value=&#34;quarter&#34;&gt;四分音符&lt;/option&gt;
            &lt;option value=&#34;eighth&#34;&gt;八分音符&lt;/option&gt;
            &lt;option value=&#34;triplet&#34;&gt;三连音&lt;/option&gt;
            &lt;option value=&#34;sixteenth&#34;&gt;十六分音符&lt;/option&gt;
        &lt;/select&gt;
        &lt;br&gt;&lt;br&gt;
        &lt;button id=&#34;startBtn&#34;&gt;开始&lt;/button&gt;
        &lt;button id=&#34;stopBtn&#34; disabled&gt;停止&lt;/button&gt;
    &lt;/div&gt;
    &lt;script src=&#34;http://localhost:1313/metronome/metronome.js&#34;&gt;&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;
</description>
        </item>
