&lt;/h1&gt;&lt;ul&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;#step-1-%e4%b8%80%e4%ba%9b%e5%b8%b8%e7%94%a8%e7%9a%84%e8%8a%82%e5%a5%8f%e7%bb%84%e5%90%88&#34; &gt;Step-1 дёҖдәӣеёёз”Ёзҡ„иҠӮеҘҸз»„еҗҲ&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;#step-2-%e4%b8%80%e4%ba%9b%e8%a7%84%e5%88%99&#34; &gt;Step-2 дёҖдәӣи§„еҲҷ&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;#step-3-%e7%bb%99%e5%88%9a%e6%89%8d%e7%bc%96%e9%85%8d%e5%a5%bd%e7%9a%84%e6%89%8b%e6%b3%95%e8%ae%be%e8%ae%a1%e8%bf%87%e9%bc%93%e8%b7%af%e5%be%84&#34; &gt;Step-3 з»ҷеҲҡжүҚзј–й…ҚеҘҪзҡ„жүӢжі•и®ҫи®ЎиҝҮйј“и·Ҝеҫ„&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;#step-4-%e5%8a%a0%e5%85%a5%e5%88%b0%e9%9f%b3%e4%b9%90%e5%8e%bb%e8%af%95%e8%af%95%e5%90%a7%ef%bc%81%ef%bc%81&#34; &gt;Step-4 еҠ е…ҘеҲ°йҹід№җеҺ»иҜ•иҜ•еҗ§пјҒпјҒ&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;#%e4%b8%80%e4%ba%9b%e5%a5%bd%e5%90%ac%e7%9a%84%e8%ae%be%e8%ae%a1&#34; &gt;дёҖдәӣеҘҪеҗ¬зҡ„и®ҫи®Ў&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h1 id=&#34;step-1-дёҖдәӣеёёз”Ёзҡ„иҠӮеҘҸз»„еҗҲдҪ д№ҹеҸҜд»ҘеҶҷиҮӘе·ұзҡ„з»„еҗҲ&#34;&gt;Step-1 дёҖдәӣеёёз”Ёзҡ„иҠӮеҘҸз»„еҗҲпјҲдҪ д№ҹеҸҜд»ҘеҶҷиҮӘе·ұзҡ„з»„еҗҲпјү
&lt;/h1&gt;&lt;p&gt;&lt;img src=&#34;http://localhost:1313/post/%e6%8a%80%e6%9c%af/%e5%a6%82%e4%bd%95%e8%ae%be%e8%ae%a1%e5%87%ba%e5%a5%bd%e5%90%ac%e7%9a%84%e6%b5%81%e8%a1%8c%e5%8a%a0%e8%8a%b1/1.PNG&#34;
	
	
	
	loading=&#34;lazy&#34;
	
	
&gt;&lt;/p&gt;
&lt;h1 id=&#34;step-2-дёҖдәӣи§„еҲҷ&#34;&gt;Step-2 дёҖдәӣи§„еҲҷ
&lt;/h1&gt;&lt;ol&gt;
&lt;li&gt;
&lt;p&gt;жүҫеҮәиҝҷдёӘеҠ иҠұдёӯзҡ„&lt;strong&gt;й•ҝйҹіз¬ҰпјҲзӯүдәҺжҲ–еӨ§дәҺе…«еҲҶйҹіз¬Ұпјү&lt;/strong&gt;пјҢ&lt;strong&gt;йҖүжӢ©жҖ§зҡ„еҠ е…ҘеҚ•иЈ…йҘ°йҹіжҲ–ејҖй•ІгҖҒеҗҠй•ІжқҘеҲ¶йҖ еҠЁжҖҒгҖӮ&lt;/strong&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;жҜҸдёӘ&lt;strong&gt;й•ҝйҹіз¬ҰеҗҺйқўзҡ„йҹіеҸҜд»ҘжҠҠжүӢжӣҝжҚўжҲҗеә•йј“&lt;/strong&gt;пјҢжӣҙиҝӣдёҖжӯҘеҲ¶йҖ еҠЁжҖҒгҖӮпјҲжіЁж„Ҹиҝһз»ӯзҡ„еә•йј“дёҚиҰҒи¶…иҝҮдёӨдёӘпјҢиҝҷж ·дјҡеҗ¬иө·жқҘеҫҲе‘ҶгҖӮпјү&lt;/p&gt;
&lt;/li&gt;
&lt;/ol&gt;
&lt;h1 id=&#34;step-3-з»ҷеҲҡжүҚзј–й…ҚеҘҪзҡ„жүӢжі•и®ҫи®ЎиҝҮйј“и·Ҝеҫ„&#34;&gt;Step-3 з»ҷеҲҡжүҚзј–й…ҚеҘҪзҡ„жүӢжі•и®ҫи®ЎиҝҮйј“и·Ҝеҫ„
&lt;/h1&gt;&lt;p&gt;&lt;img src=&#34;http://localhost:1313/post/%e6%8a%80%e6%9c%af/%e5%a6%82%e4%bd%95%e8%ae%be%e8%ae%a1%e5%87%ba%e5%a5%bd%e5%90%ac%e7%9a%84%e6%b5%81%e8%a1%8c%e5%8a%a0%e8%8a%b1/2.PNG&#34;
	
	
	
	loading=&#34;lazy&#34;
	
	
&gt;&lt;/p&gt;
&lt;h1 id=&#34;step-4-еҠ е…ҘеҲ°йҹід№җеҺ»иҜ•иҜ•еҗ§&#34;&gt;Step-4 еҠ е…ҘеҲ°йҹід№җеҺ»иҜ•иҜ•еҗ§пјҒпјҒ
&lt;/h1&gt;&lt;p&gt;иҝҷж ·дёҖдёӘеҘҪеҗ¬зҡ„жөҒиЎҢеҠ иҠұе°ұе®ҢжҲҗдәҶпјҢжҠҠи®ҫи®ЎеҘҪзҡ„еҠ иҠұж”ҫиҝӣдёҚеҗҢзҡ„йҹід№җиҜ•иҜ•еҗ§пјҒпјҒ&lt;/p&gt;
&lt;h1 id=&#34;дёҖдәӣеҘҪеҗ¬зҡ„и®ҫи®Ў&#34;&gt;дёҖдәӣеҘҪеҗ¬зҡ„и®ҫи®Ў
&lt;/h1&gt;</description>
